# Провайдер LLM: fake (по умолчанию) | gigachat
LLM_PROVIDER=fake

# --- GigaChat API ---
# Документация: https://developers.sber.ru/docs/ru/gigachat/individuals-quickstart

# Ключ авторизации
GIGACHAT_CREDENTIALS=

# Версия API
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель
GIGACHAT_MODEL=GigaChat

# Сертификаты НУЦ Минцифры обязательны для Python-клиентов
GIGACHAT_CA_BUNDLE_FILE=certs/russiantrustedca.pem

# Проверка SSL
GIGACHAT_VERIFY_SSL_CERTS=true

# Таймаут запроса, секунды
GIGACHAT_TIMEOUT=60

# Опционально: повторы при временных ошибках
GIGACHAT_MAX_RETRIES=3

# --- PostgreSQL ---
POSTGRES_DB=ege_grader
POSTGRES_USER=ege
POSTGRES_PASSWORD=ege_dev
POSTGRES_PORT=5432

# Порт API при запуске через docker compose
APP_PORT=8000

# Локальный запуск uvicorn (без docker). Для docker compose URL собирается автоматически.
# Если не задано — in-memory хранилище (режим по умолчанию).
# DATABASE_URL=postgresql+psycopg://ege:ege_dev@localhost:5432/ege_grader
